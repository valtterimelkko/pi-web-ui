# Pi Web UI example configuration
#
# Copy to .env for local use:
#   cp .env.example .env
#
# This file intentionally uses placeholder/example values only.
# Do NOT put real secrets in a tracked file.

# ─── Core app ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Browser auth/session secret (required in production)
JWT_SECRET=replace-with-a-random-secret
JWT_EXPIRES_IN=30d

# CSRF secret (required in production / checked by config validation)
CSRF_SECRET=replace-with-a-random-secret

# Single-user browser login password.
# Development: plain text is acceptable for local use.
# Production: use a bcrypt hash instead.
AUTH_PASSWORD=change-me-for-local-dev

# Comma-separated browser origins allowed to connect.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# ─── Rate limiting ────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Pi SDK path ─────────────────────────────────────────────────
# Leave blank to use the default (~/.pi/agent)
PI_AGENT_DIR=

# Optional override for Pi session directory
SESSION_DIR=

# Optional: Pi stale-stream reset window
PI_STALE_STREAMING_MS=900000

# ─── Claude runtime ───────────────────────────────────────────────
# Optional override for Pi-owned Claude replay storage
CLAUDE_SESSION_DIR=

# Legacy/direct Claude process limit
MAX_CLAUDE_PROCESSES=10

# Channel-backed Claude Code path (opt-in)
CLAUDE_CHANNEL_ENABLED=false
CLAUDE_CHANNEL_PLUGIN_DIR=./pi-claude-channel
CLAUDE_CHANNEL_WS_PORT=3100
CLAUDE_CHANNEL_HOOK_PORT=3101

# ─── OpenCode Direct ──────────────────────────────────────────────
# Set to false if you do not want the OpenCode runtime path enabled.
OPENCODE_ENABLED=true
OPENCODE_SERVER_HOST=127.0.0.1
OPENCODE_SERVER_PORT=4096
OPENCODE_SERVER_PASSWORD=
OPENCODE_WORKING_DIR=

# Session/lifecycle controls
OPENCODE_MAX_SESSIONS=4
OPENCODE_IDLE_TIMEOUT_MS=1800000
OPENCODE_STALE_STREAMING_MS=900000
OPENCODE_MAX_PINNED_SESSIONS=2
OPENCODE_CLEANUP_INTERVAL_MS=60000

# Debugging only: forward unknown SSE events as opencode_raw
OPENCODE_DEBUG_RAW_EVENTS=false

# Trusted mode reduces repeat approval prompts for trusted autonomous work.
# Pi Web UI still adds deny rules for catastrophic shell patterns.
OPENCODE_TRUSTED_PERMISSIONS=false

# Approval mode for accepted OpenCode permission prompts: always | once
OPENCODE_PERMISSION_APPROVE_MODE=always

# Recycle the OpenCode backend after this uptime, but only while idle.
# Set to 0 to disable idle-aware recycling.
OPENCODE_SERVER_MAX_UPTIME_MS=86400000

# Optional provider key used in some OpenCode-backed workflows
DEEPSEEK_API_KEY=

# ─── Antigravity ──────────────────────────────────────────────────
# Set to false if you do not want the Antigravity runtime path enabled.
ANTIGRAVITY_ENABLED=true
ANTIGRAVITY_SESSION_DIR=
ANTIGRAVITY_DEFAULT_MODEL=Gemini 3.5 Flash (Medium)
ANTIGRAVITY_PROMPT_TIMEOUT_MS=600000
ANTIGRAVITY_IDLE_TIMEOUT_MS=1800000
ANTIGRAVITY_MAX_SESSIONS=4
ANTIGRAVITY_MAX_PINNED_SESSIONS=2
ANTIGRAVITY_CLEANUP_INTERVAL_MS=60000

# Optional override if agy is not on PATH
AGY_BINARY=

# ─── Dictation / text-to-speech ───────────────────────────────────
# If TTS_OPENAI_API_KEY is omitted, TTS falls back to OPENAI_API_KEY or
# DICTATION_OPENAI_API_KEY depending on the path.
OPENAI_API_KEY=
DICTATION_OPENAI_API_KEY=
TTS_OPENAI_API_KEY=
TTS_MODEL=tts-1

# Optional local dictation vocabulary database override
DICTATION_VOCABULARY_DB_PATH=

# ─── Local automation API (currently documented as Internal API) ──
# Local-only Unix-socket API used for live validation, integrations,
# and orchestration experiments.
INTERNAL_API_ENABLED=true
INTERNAL_API_SOCKET_PATH=
INTERNAL_API_KEY=
INTERNAL_API_TOKEN_PATH=

# ─── Session registry override ────────────────────────────────────
SESSION_REGISTRY_PATH=
