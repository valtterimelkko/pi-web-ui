# Pi Web UI example configuration
#
# Copy to .env for local use:
#   cp .env.example .env
#
# This file intentionally uses placeholder/example values only.
# Do NOT put real secrets in a tracked file.

# ─── Core app ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Logging / observability ──────────────────────────────────────
# Minimum severity emitted by the central logger. One of: error | warn | info | debug.
# - error: failures needing attention
# - warn:  recoverable anomalies
# - info:  lifecycle milestones (default)
# - debug: per-operation detail
# Invalid values fall back to info. See docs/OBSERVABILITY.md.
LOG_LEVEL=info

# Per-component debug namespaces. Comma-separated component names with `*`
# wildcards (case-insensitive). When set, ONLY matching components emit; all
# others are suppressed. Combine with LOG_LEVEL=debug for full detail on one
# subsystem. Unset = off (all components emit per LOG_LEVEL).
# Examples: DEBUG=claude,opencode*  |  DEBUG=claude*  |  DEBUG=*
DEBUG=

# Log line format: pretty (human-readable, default) or json (one JSON object per
# line — cheaper for agents/tools to filter). See docs/OBSERVABILITY.md.
LOG_FORMAT=pretty

# Browser auth/session secret (required in production)
JWT_SECRET=replace-with-a-random-secret
JWT_EXPIRES_IN=30d

# CSRF secret (required in production / checked by config validation)
CSRF_SECRET=replace-with-a-random-secret

# Single-user browser login password.
# Development: plain text is acceptable for local use.
# Production: use a bcrypt hash instead.
AUTH_PASSWORD=change-me-for-local-dev

# Comma-separated browser origins allowed to connect.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# ─── Rate limiting ────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Pi SDK path ─────────────────────────────────────────────────
# Leave blank to use the default (~/.pi/agent)
PI_AGENT_DIR=

# Optional override for Pi session directory
SESSION_DIR=

# Optional: Pi stale-stream reset window
PI_STALE_STREAMING_MS=900000

# ─── Claude runtime ───────────────────────────────────────────────
# Optional override for Pi-owned Claude replay storage
CLAUDE_SESSION_DIR=

# Legacy/direct Claude process limit
MAX_CLAUDE_PROCESSES=10

# Channel-backed Claude Code path (opt-in)
CLAUDE_CHANNEL_ENABLED=false
CLAUDE_CHANNEL_PLUGIN_DIR=./pi-claude-channel
CLAUDE_CHANNEL_WS_PORT=3100
CLAUDE_CHANNEL_HOOK_PORT=3101
# Opt-in channel activity logs (payloads/prompts/secrets remain redacted).
CLAUDE_CHANNEL_DEBUG=false

# ─── Claude provider profiles (SDK + direct CLI) ────────────────
# Profiles let you run Claude through different backends and providers
# (native subscription, GLM/Z.ai, etc.) without editing ~/.claude/settings.json.
# Profile config file (default: ~/.pi-web-ui/claude-profiles.json)
CLAUDE_PROFILES_PATH=
# Enable the profile system (opt-in)
CLAUDE_PROFILES_ENABLED=false
# Enable the Claude Agent SDK backend (default: true when profiles enabled)
CLAUDE_SDK_ENABLED=true
# Enable direct CLI profile support (default: true)
CLAUDE_DIRECT_PROFILES_ENABLED=true
# Default profile id to use for new Claude sessions
CLAUDE_DEFAULT_PROFILE=
# Default backend when no profile is selected: sdk | direct | channel
CLAUDE_BACKEND_DEFAULT=direct
# Timeout for Claude SDK AskUserQuestion dialogs (positive integer ms).
# Default is 30 minutes. A 5-minute default caused a production zombie-dialog
# bug, so the current default is intentionally a long safety net.
# CLAUDE_ASK_USER_QUESTION_TIMEOUT_MS=1800000
# Grace period after the last browser subscriber disconnects from an AskUserQuestion.
# Default is 120 seconds; this is the primary abandonment signal, not the wall-clock timeout.
# CLAUDE_ASK_USER_QUESTION_DISCONNECT_GRACE_MS=120000
# Transient-failure retries for Claude turns (model "temporarily unavailable",
# overload, 5xx, socket errors, or a silent empty result). Applies to both the
# SDK and direct-CLI backends. Set MAX_RETRIES=0 to disable.
CLAUDE_TRANSIENT_MAX_RETRIES=2
CLAUDE_TRANSIENT_BASE_DELAY_MS=1000
CLAUDE_TRANSIENT_MAX_DELAY_MS=15000

# ─── OpenCode Direct ──────────────────────────────────────────────
# Set to false if you do not want the OpenCode runtime path enabled.
OPENCODE_ENABLED=true
OPENCODE_SERVER_HOST=127.0.0.1
OPENCODE_SERVER_PORT=4096
OPENCODE_SERVER_PASSWORD=
OPENCODE_WORKING_DIR=

# Which OpenCode providers' models appear in the web UI model picker.
# Comma-separated provider ids, or "all"/"*" for every provider OpenCode reports.
# API keys are NEVER read or stored by Pi Web UI — they live only in OpenCode's
# own auth storage (~/.local/share/opencode/auth.json and ~/.config/opencode/
# opencode.json). Pi Web UI just reads the /config/providers catalogue.
# Examples: zai-coding-plan,kilo,opencode  (default) | all
OPENCODE_MODEL_PROVIDERS=zai-coding-plan,kilo,opencode

# Host-side audit snapshot for the weekly model-refresh job (ids only, no secrets).
# Defaults to ~/.pi-web-ui/opencode-model-snapshot.json when unset.
OPENCODE_MODEL_SNAPSHOT_PATH=

# ─── Pi runtime: OpenRouter model automation ──────────────────────────────────
# Surface the full OpenRouter gateway catalogue in the Pi runtime model picker.
# See docs/PI-OPENROUTER-MODEL-AUTOMATION.md. The catalogue (public model ids and
# pricing/capability metadata only) is fetched from openrouter.ai/api/v1/models,
# cached host-side, and registered into the Pi SDK ModelRegistry. No secrets are
# stored: OpenRouter is a built-in Pi SDK provider.
#
# Routing auth: PREFERRED — authenticate once with the Pi SDK so the key lives in
# ~/.pi/agent/auth.json (mode 0600, gitignored), exactly like the OAuth providers
# (openai-codex, anthropic, …). The server reads auth.json; no env entry needed.
#   pi auth login   # or set {type:'api_key', key} via the SDK's AuthStorage
# OPTIONAL FALLBACK: the Pi SDK also auto-detects OPENROUTER_API_KEY from the env
# (see @earendil-works/pi-ai env-api-keys.js). SECRET — never commit a real value;
# leave blank here and provision via auth.json instead.
OPENROUTER_API_KEY=
# Set to "false" to disable OpenRouter model surfacing entirely.
PI_OPENROUTER_MODELS_ENABLED=true
# Cache + snapshot paths (public metadata only, no secrets). Default to
# ~/.pi-web-ui/pi-openrouter-models.json and -snapshot.json when unset.
PI_OPENROUTER_MODELS_CACHE_PATH=
PI_OPENROUTER_MODELS_SNAPSHOT_PATH=

# Session/lifecycle controls
OPENCODE_MAX_SESSIONS=4
OPENCODE_IDLE_TIMEOUT_MS=1800000
OPENCODE_STALE_STREAMING_MS=900000
OPENCODE_MAX_PINNED_SESSIONS=2
OPENCODE_CLEANUP_INTERVAL_MS=60000

# Debugging only: forward unknown SSE events as opencode_raw
OPENCODE_DEBUG_RAW_EVENTS=false

# Trusted mode reduces repeat approval prompts for trusted autonomous work.
# Pi Web UI still adds deny rules for catastrophic shell patterns.
OPENCODE_TRUSTED_PERMISSIONS=false

# Approval mode for accepted OpenCode permission prompts: always | once
OPENCODE_PERMISSION_APPROVE_MODE=always

# Recycle the OpenCode backend after this uptime, but only while idle.
# Set to 0 to disable idle-aware recycling.
OPENCODE_SERVER_MAX_UPTIME_MS=86400000

# DeepSeek provider key. PREFERRED: authenticate via the Pi SDK so it lives in
# ~/.pi/agent/auth.json (gitignored), like the OAuth providers. The server reads
# auth.json; no env entry is required. OPTIONAL FALLBACK: the Pi SDK also
# auto-detects DEEPSEEK_API_KEY from the env (and persists it to auth.json on
# first use). SECRET — never commit a real value; leave blank here.
DEEPSEEK_API_KEY=

# ─── Antigravity ──────────────────────────────────────────────────
# Set to false if you do not want the Antigravity runtime path enabled.
ANTIGRAVITY_ENABLED=true
ANTIGRAVITY_SESSION_DIR=
ANTIGRAVITY_DEFAULT_MODEL=Gemini 3.5 Flash (Medium)
ANTIGRAVITY_PROMPT_TIMEOUT_MS=600000
ANTIGRAVITY_IDLE_TIMEOUT_MS=1800000
ANTIGRAVITY_MAX_SESSIONS=4
ANTIGRAVITY_MAX_PINNED_SESSIONS=2
ANTIGRAVITY_CLEANUP_INTERVAL_MS=60000
# Liveness heartbeat cadence (ms) during an in-flight Antigravity turn (batch subprocess; synthetic stream_activity ping)
ANTIGRAVITY_HEARTBEAT_INTERVAL_MS=5000
# Kill a turn early if its --log-file stops growing for this long (ms) — a stuck agy subprocess, not a live backend call
ANTIGRAVITY_STALL_TIMEOUT_MS=300000
# Bounded attempt count (including the first try) for a turn that stalls or times out
ANTIGRAVITY_MAX_ATTEMPTS=2

# Optional override if agy is not on PATH
AGY_BINARY=

# ─── Dictation / text-to-speech ───────────────────────────────────
# If TTS_OPENAI_API_KEY is omitted, TTS falls back to OPENAI_API_KEY or
# DICTATION_OPENAI_API_KEY depending on the path.
OPENAI_API_KEY=
DICTATION_OPENAI_API_KEY=
TTS_OPENAI_API_KEY=
TTS_MODEL=tts-1

# Optional local dictation vocabulary database override
DICTATION_VOCABULARY_DB_PATH=

# ─── Local automation API (currently documented as Internal API) ──
# Local-only Unix-socket API used for live validation, integrations,
# and orchestration experiments.
INTERNAL_API_ENABLED=true
INTERNAL_API_SOCKET_PATH=
INTERNAL_API_KEY=
INTERNAL_API_TOKEN_PATH=
# Directory for durable long-horizon watch ledgers (default ~/.pi-web-ui/watches)
INTERNAL_API_WATCH_DIR=
# Directory for persisted run receipts (default ~/.pi-web-ui/run-receipts)
INTERNAL_API_RUN_RECEIPTS_DIR=
# Session-scoped idempotency replay window for run dispatches (default 24h, ms)
INTERNAL_API_RUN_IDEMPOTENCY_TTL_MS=86400000
# Directory for the durable API-pin expiry ledger (default ~/.pi-web-ui/pins)
INTERNAL_API_PIN_DIR=
# API-pin lifetime: default 24h, hard max 7d, in milliseconds.
INTERNAL_API_PIN_DEFAULT_TTL_MS=86400000
INTERNAL_API_PIN_MAX_TTL_MS=604800000
# How often expired API pins are swept (default 5 min, in milliseconds).
INTERNAL_API_PIN_EXPIRY_INTERVAL_MS=300000
# Ephemeral validation mode: disables session cleanup + skips real-session
# registry rebuild so a disposable validation instance can't touch real data.
# You normally don't set this by hand — `npm run validate:server` sets it.
PI_WEB_UI_VALIDATION_MODE=false

# ─── Notification layer (Telegram) ────────────────────────────────
# One-way operator notifications on agent_end (any runtime) + an explicit
# POST /api/v1/notifications for Agent OS / scripts. See docs/NOTIFICATIONS.md.
# Master switch. When false the manager is inert (no observers, no sends).
NOTIFICATIONS_ENABLED=false
# Persistence dir for opt-ins + the durable delivery outbox/log.
NOTIFICATIONS_DIR=
# Coalesce multiple agent_ends for one session within this window (ms).
NOTIFICATIONS_DEBOUNCE_MS=1500
# Tail length before truncation (well under Telegram's 4096-char limit).
NOTIFICATIONS_TAIL_MAX_CHARS=1200
# Base URL for deep links back into a session (defaults to first ALLOWED_ORIGIN).
NOTIFICATIONS_PUBLIC_BASE_URL=
# Outbox retry cap before a delivery is marked failed.
NOTIFICATIONS_MAX_DELIVERY_ATTEMPTS=5
# Positive interval for draining locally spooled terminal notifications (ms).
NOTIFICATIONS_INGRESS_POLL_MS=5000
# Positive per-attempt Telegram timeout including response-body read (ms).
NOTIFICATIONS_CHANNEL_TIMEOUT_MS=10000
# Dedicated Telegram bot. SECRET — never commit a real value; provision via the
# local un-committed .env only. If either is unset, Telegram reports not configured.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Session registry override ────────────────────────────────────
SESSION_REGISTRY_PATH=
