# Server Configuration
PORT=3000
NODE_ENV=development

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Password for single-user mode
AUTH_PASSWORD=your-secure-password-here

# Security
# Comma-separated list of allowed origins for CORS and WebSocket
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Pi SDK Configuration
# Path to Pi agent directory (default: ~/.pi/agent)
PI_AGENT_DIR=

# Session Configuration
SESSION_DIR=

# OpenCode Direct Integration
# Port for the OpenCode backend server (default: 4096)
OPENCODE_SERVER_PORT=4096
# Host for the OpenCode backend server (default: 127.0.0.1)
OPENCODE_SERVER_HOST=127.0.0.1
# Password for OpenCode server basic auth (optional)
OPENCODE_SERVER_PASSWORD=
# Set to 'false' to disable OpenCode Direct integration
OPENCODE_ENABLED=true
# Working directory for OpenCode sessions (default: current working directory)
OPENCODE_WORKING_DIR=
