# Server Configuration
PORT=3000
NODE_ENV=development

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=30d

# Password for single-user mode
AUTH_PASSWORD=your-secure-password-here

# Security
# Comma-separated list of allowed origins for CORS and WebSocket
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Pi SDK Configuration
# Path to Pi agent directory (default: ~/.pi/agent)
PI_AGENT_DIR=

# Session Configuration
SESSION_DIR=

# OpenCode Direct Integration
# Port for the OpenCode backend server (default: 4096)
OPENCODE_SERVER_PORT=4096
# Host for the OpenCode backend server (default: 127.0.0.1)
OPENCODE_SERVER_HOST=127.0.0.1
# Password for OpenCode server basic auth (optional)
OPENCODE_SERVER_PASSWORD=
# Set to 'false' to disable OpenCode Direct integration
OPENCODE_ENABLED=true
# Working directory for OpenCode sessions (default: current working directory)
OPENCODE_WORKING_DIR=
# Set to 'true' to forward unknown SSE events as opencode_raw (debugging only)
OPENCODE_DEBUG_RAW_EVENTS=false

# When true, new OpenCode Direct sessions are created with permissive session-level
# permissions so long-running tasks can proceed without repeated browser approval
# prompts. Catastrophic disk/system commands remain denied by server defaults.
OPENCODE_TRUSTED_PERMISSIONS=false

# How to reply when a user approves an OpenCode permission prompt: "always" reduces
# repeat prompts within the same OpenCode session; "once" preserves one-shot approval.
OPENCODE_PERMISSION_APPROVE_MODE=always

# Recycle the OpenCode backend after this uptime, but only when no OpenCode
# Direct session is actively running. Set to 0 to disable idle-aware recycling.
OPENCODE_SERVER_MAX_UPTIME_MS=86400000
# DeepSeek API key (optional) - enables native deepseek provider models
DEEPSEEK_API_KEY=

# OpenAI API key (optional) - enables dictation (STT) and read-aloud (TTS)
# If TTS_OPENAI_API_KEY is omitted, it falls back to OPENAI_API_KEY or DICTATION_OPENAI_API_KEY
OPENAI_API_KEY=
DICTATION_OPENAI_API_KEY=
TTS_OPENAI_API_KEY=

# ─── Internal Backend API ────────────────────────────────────────────
# Exposes the Pi Web UI backend over a Unix socket for programmatic
# consumption by other local applications (voice, agent OS, etc.)

# Set to 'false' to disable the internal API
INTERNAL_API_ENABLED=true

# Path to the Unix domain socket (default: ~/.pi-web-ui/internal-api.sock)
INTERNAL_API_SOCKET_PATH=

# Pre-set API key for authentication (auto-generated if left empty)
INTERNAL_API_KEY=

# Path to store the auto-generated API token
INTERNAL_API_TOKEN_PATH=

# Claude Channel Integration (opt-in, uses subscription quota instead of SDK credit)
CLAUDE_CHANNEL_ENABLED=false
CLAUDE_CHANNEL_PLUGIN_DIR=./pi-claude-channel
CLAUDE_CHANNEL_WS_PORT=3100
CLAUDE_CHANNEL_HOOK_PORT=3101
