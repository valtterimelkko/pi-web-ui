{
  "name": "pi-web-ui",
  "version": "0.1.0",
  "private": true,
  "description": "A self-hosted multi-runtime web UI for coding agents",
  "workspaces": [
    "server",
    "client",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=shared && npm run build --workspace=server && npm run build --workspace=client",
    "start": "npm run start --workspace=server",
    "test": "npm run test --workspace=server && npm run test --workspace=client",
    "test:coverage": "npm run test:coverage --workspace=server && npm run test:coverage --workspace=client",
    "test:e2e": "playwright test",
    "benchmark": "vitest bench --config tests/benchmarks/vitest.bench.config.ts",
    "benchmark:quick": "tsx tests/benchmarks/index.ts",
    "validate:live": "npx tsx scripts/live-validate.ts",
    "validate:long-horizon": "npx tsx scripts/long-horizon-validate.ts",
    "validate:server": "npx tsx scripts/validation-server.ts",
    "validate:claude-profiles": "npx tsx scripts/validate-claude-profiles.ts",
    "opencode:refresh-models": "npx tsx scripts/opencode-refresh-models.ts",
    "debug:where": "node scripts/debug-where.mjs",
    "docs:sync-agent-guides": "node scripts/sync-agent-guides.mjs",
    "docs:check-agent-guides": "node scripts/check-agent-guides.mjs",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "npm run build --workspace=shared && npm run typecheck --workspace=server && npm run typecheck --workspace=client && npm run typecheck --workspace=shared"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/compression": "^1.8.1",
    "@types/node": "^20.10.0",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "playwright": "^1.58.2",
    "supertest": "^6.3.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.6",
    "@types/multer": "^2.1.0",
    "compression": "^1.8.1",
    "multer": "^2.1.1",
    "uuid": "^14.0.0"
  }
}
