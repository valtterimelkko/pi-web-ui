class":"font-medium text-primary"},"/","skill:notion-create-note"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Create a new note in the Notion Note inbox. Use when the user wants to create a new note, capture ideas, or start a new document in the Ultimate Brain system."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:notion-create-project"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Create a new project in the Notion Projects database. Use when the user wants to start a new project, add a project for organizing notes, or set up a new work initiative in the Ultimate Brain system."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:notion-edit-note"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Edit content of a Notion note. Use when the user wants to add, replace, or clear content in an existing note in the Ultimate Brain system."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:notion-list-project-notes"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"List all notes belonging to a Notion project. Use when the user wants to see all notes in a project, get an overview of project documentation, or find note IDs in the Ultimate Brain system."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:notion-list-projects"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"List all projects from the Notion Projects database. Use when the user wants to see available projects, find project IDs, or get an overview of their project portfolio in the Ultimate Brain system."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:notion-read-note"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Read the full content of a Notion note. Use when the user wants to view or access note content by ID or name from the Ultimate Brain system."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:notion-search-notes"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Search for notes by keyword in Notion. Use when the user wants to find notes containing specific keywords or search within projects in the Ultimate Brain system."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:openapi-schema"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Create OpenAPI 3.1.0 schema files for OpenAI Custom GPTs Actions. Use when the user needs to (1) Generate OpenAPI schemas for GPT actions/API integrations, (2) Convert API documentation to OpenAPI format, (3) Validate or fix existing OpenAPI schemas for GPT compatibility, (4) Add authentication configurations (API Key, OAuth 2.0), (5) Create schemas for specific HTTP methods (GET, POST, PUT, DELETE), (6) Structure request/response models for GPT consumption."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:pdf"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Comprehensive PDF manipulation toolkit for extracting text and tables, creating new PDFs, merging/splitting documents, and handling forms. When Claude needs to fill in a PDF form or programmatically process, generate, or analyze PDF documents at scale."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:pi-extension"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Create Pi extensions with custom tools, commands, UI components, and event handlers. Use when: building custom tools for Pi, adding new slash commands, creating UI widgets/overlays, handling lifecycle events, modifying agent behavior, integrating external services, or building reusable Pi packages. Covers ExtensionAPI, registerTool, registerCommand, event handlers, custom editors, keyboard shortcuts, TUI components, and 50+ official examples. ALWAYS use when extending Pi beyond built-in capabilities."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:pi-sdk"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Build applications with Pi SDK for programmatic AI agent integration. Use when: embedding Pi in Node.js/TypeScript apps, creating custom agent interfaces, building headless automation, integrating AI into existing tools, managing sessions programmatically, or building on top of Pi's agent runtime. Covers createAgentSession, SessionManager, AuthStorage, ModelRegistry, tools, extensions, event streaming, and all run modes (Interactive, Print, JSON, RPC, SDK). ALWAYS use for programmatic Pi integration beyond CLI usage."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:playwright-cli"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"CLI-based browser automation for testing live websites, extracting data, and interacting with web pages. Use for: testing external/production sites (NOT localhost), form filling on live websites, taking screenshots of public pages, mocking API responses, managing browser sessions and cookies, recording videos of user flows, and extracting information from any accessible URL. ALWAYS use when the user mentions playwright-cli, wants to mock network requests, save/restore browser state, record browser videos, or automate interactions on live/production websites. DO NOT use for local development servers - use webapp-testing skill instead. Keywords: playwright-cli, browser CLI, web automation, form filling, screenshots, network mocking, session management, cookie handling, video recording, live site testing, production testing."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:pptx"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Presentation creation, editing, and analysis. When Claude needs to work with presentations (.pptx files) for: (1) Creating new presentations, (2) Modifying or editing content, (3) Working with layouts, (4) Adding comments or speaker notes, or any other presentation tasks"]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:pptx-draft"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Convert PowerPoint presentations to structured markdown for LLM-assisted editing, then convert back to PowerPoint with preserved formatting and layout. Use when you need to draft, edit, or work on .pptx files interactively."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:remotion"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Best practices for building videos with Remotion (React-based video framework). Use when: writing/editing Remotion code, implementing animations/transitions/timing, working with audio/subtitles/voiceovers, adding 3D content/charts/Lottie, using FFmpeg for video operations, or handling assets/fonts/images. ALWAYS use for ANY Remotion code, components, or video projects. Covers: animations, audio, video embedding, subtitles, 3D (Three.js), charts, timing, transitions, text animations, TailwindCSS, sequencing, FFmpeg, voiceover, fonts, images, GIFs, Lottie, light leaks, maps (Mapbox), and transparent videos."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:remotion-assets"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Generate video assets for Remotion using AI image generation via Runware API. Use when creating marketing videos, intro sequences, or any video content requiring images (logos, backgrounds, scenes, characters, UI mockups, abstract visuals). Handles asset planning, image generation with purpose-optimized models (Nano Banana 2 for text/UI, FLUX.1 for cinematic scenes), polling, and downloading. Supports both custom asset plans and extraction from video production plans."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:saas-blogposts"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Generate comprehensive 50-post SEO-optimized blog campaigns for SaaS products and deploy to Decap CMS with scheduled publishing. Creates content plan, writes posts with parallel agents, generates images, and deploys to Decap with GitHub Actions scheduling. Use when creating blog content strategies for SaaS products with Decap CMS headless blog integration."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:saas-idea-finder"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Uses rotating lenses (7 different daily perspectives) to discover trending topics from HackerNews, HN Algolia, DEV.to, GitHub, arXiv, Stack Exchange, GDELT, SerpAPI, YouTube, Reddit, Twitter/X, and Instagram. Generates actionable Micro-SaaS ideas using deep research with viability scoring (0-100), enhanced templates, and JTBD framework. Daily automated discovery with deduplication. Use when: (1) User asks for SaaS/startup ideas, (2) User wants to discover trending topics in tech/business, (3) Daily automated idea generation is needed."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:savonia-referencing"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Comprehensive Savonia University Harvard referencing guide for accurate citation across all source types. Use when formatting citations for books, journals, websites, legal documents, social media, and other sources; creating in-text citations; applying exact formatting rules (punctuation, author format, dates); handling edge cases (missing author/date, secondary sources, AI usage); or checking reference list formatting for academic work at Savonia University of Applied Sciences."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:scraping-reddit"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Production-quality Reddit scraping skill for discovering SaaS opportunities. Navigate Reddit programmatically to identify unaddressed user frustrations, high-intent signals, and emerging market trends. Uses Reddit's legacy .json endpoints with OAuth2 support, circuit breaker patterns, and comprehensive error handling. Provides tactical navigation (subreddit discovery, wiki scanning, contributor analysis), advanced filtering (intent patterns, sentiment scoring, velocity tracking), and idea synthesis (trend persistence, cross-pollination detection). Use when: (1) Researching SaaS opportunities on Reddit, (2) Analyzing competitor mentions and gaps, (3) Finding high-intent user pain points, (4) Tracking trend persistence across communities, (5) Discovering cross-niche opportunities."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:scraping-twitter"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Production-quality Twitter/X scraping skill for discovering SaaS opportunities. Navigate Twitter programmatically to identify unaddressed user frustrations, high-intent signals, and emerging market trends. Uses TwitterAPI.io for fast, cost-effective data extraction with simple API key authentication. Provides tactical navigation (user discovery, hashtag analysis), advanced filtering (intent patterns, sentiment scoring, velocity tracking), and idea synthesis (trend persistence, cross-pollination detection). Use when: (1) Researching SaaS opportunities on Twitter/X, (2) Analyzing competitor mentions and gaps, (3) Finding high-intent user pain points, (4) Tracking hashtag trends, (5) Discovering cross-niche opportunities."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:seo-product-launch"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Launch a new website or product with proper SEO infrastructure including robots.txt, sitemaps, metadata optimization, and search engine submission. Use when launching a new site, improving search engine findability, setting up Google Search Console, or implementing technical SEO foundations."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:si-word-document"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Create professionally styled Word documents following the SI Project template. Use when the user wants to create .docx files with SI branding, custom styles (subtitle, callout, caption), headings, tables, and proper formatting."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:skill-creator"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Create new skills, modify and improve existing skills, and measure skill performance. Use when users want to create a skill from scratch, update or optimize an existing skill, run evals to test a skill, benchmark skill performance with variance analysis, or optimize a skill's description for better triggering accuracy."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:skill-seekers-usage"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Guide for using Skill Seekers to automatically convert documentation websites, GitHub repositories, and PDFs into Claude AI skills. Use when a user wants to create a new skill from existing knowledge sources (docs, APIs, codebases, guides) without manually writing everything. Provides workflow guidance, configuration templates, troubleshooting, and best practices for skill generation."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:socialmedia-optimization"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Optimize websites for social media sharing with Open Graph, Twitter Cards, and meta tags. Use when implementing or improving social media preview cards, creating OG images, adding meta tags for Facebook/LinkedIn/Twitter sharing, fixing broken social previews, or validating social media markup."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:supabase-auth-setup"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Set up authentication and authorization for Supabase SaaS apps including user profiles, organization multi-tenancy, RBAC, and RLS policies. Use when: setting up new Supabase projects with auth, creating user profiles linked to auth.users, implementing SaaS multi-tenant architecture, configuring role-based access (owner/admin/member), or setting up RLS policies. ALWAYS use for ANY new Supabase SaaS project or auth configuration. Creates: profiles table, organizations table, organization_members with roles, RLS policies, auth triggers, helper functions."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:supabase-database"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Execute SQL queries, manage database schema, and handle Row Level Security (RLS) policies on Supabase PostgreSQL databases. Use when - (1) Creating tables, indexes, or database schema modifications, (2) Running SQL migrations or schema changes, (3) Querying data via SQL or PostgREST API, (4) Managing RLS policies for security and access control, (5) Inserting, updating, or deleting database records, (6) Listing tables, columns, or exploring database structure. ALWAYS use when the user mentions Supabase SQL, PostgreSQL migrations, RLS policies, table creation, database queries, schema management, or Supabase data operations. Covers - SQL execution, PostgREST CRUD operations, RLS policy management, data mutations, table listing, and schema exploration."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:supabase-project-manage"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Manage Supabase projects and organizations via the Management API - create new projects, list organizations, retrieve API keys, save credentials locally, and handle project lifecycle operations. Use when - (1) Setting up a new Supabase project or SaaS backend, (2) Creating projects with auto-generated passwords and saved credentials, (3) Retrieving API keys (anon/service_role) for application integration, (4) Listing Supabase organizations or existing projects, (5) Getting project details, connection strings, or database URLs, (6) Deleting projects or managing project settings. ALWAYS use when the user wants to create a Supabase project, get Supabase API keys, connect to Supabase backend, initialize Supabase for a new app, or manage Supabase organizations. Keywords - project creation, API credentials, database connection, PAT token, organization management, project ref, service_role key."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:thematic-analysis"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Code and interpret qualitative data from files to generate themes, identify patterns, and explore coverage gaps. Use when analyzing interview transcripts, survey responses, documents, or any text data to identify codes, develop themes, assess analytical coverage, and determine what areas have been effectively explored versus potentially avoided. Supports both reflexive thematic analysis (Braun & Clarke) and codebook approaches for research rigor. Optimized for chat-based collaborative workflows."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:using-claudecodecli"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Guide for using Claude Code CLI (`claude` command) effectively in shell workflows, pipelines, and agentic coding tasks. Use when - (1) Running `claude -p` commands for non-interactive code analysis or generation, (2) Piping command output to Claude for analysis (e.g., `git diff | claude -p`), (3) Generating commit messages from git diffs, (4) Debugging errors by piping logs to Claude, (5) Performing code reviews or generating test cases via CLI, (6) Creating shell pipelines that integrate Claude Code with other tools, (7) Using `--model`, `--tools`, or `--system-prompt` flags. ALWAYS use when the user asks about `claude` command usage, `-p` / `--print` flag, piping to Claude, commit message generation, CLI integration, shell workflows with Claude, or programmatic access to Claude Code. Keywords - claude CLI, claude -p, shell integration, git diff analysis, code review automation, agentic coding, bash pipelines, non-interactive mode."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:uwe-harvard"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Comprehensive UWE Bristol Harvard referencing guide for accurate citation across all source types. Use when formatting citations for books, journals, websites, films, legal documents, reports, and other sources; creating in-text citations and paraphrases; applying exact formatting rules (italics, punctuation, capitalization); handling edge cases (missing author/date, confidential material, generative AI); or checking reference list formatting for academic work."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:valtteris-marking-voice"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Write student feedback in Valtteri's distinctive marking voice - encouraging, constructive, and student-facing with specific phrasing patterns, softening techniques, and British English conventions. Use when writing feedback to students on assignments, presentations, workshops, portfolios, essays, or any academic work where Valtteri's personal marking style should be maintained. Not for generating marks or criteria, only for feedback writing."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:web-create-assets"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Create professional-quality UI assets (icons, hero banners, feature icons, backgrounds, product mockups, marketing materials) that stylistically match existing web applications. Analyzes screenshots for style extraction, generates comprehensive UI asset plans, and produces consistent assets using Runware API (Nano Banana 2 for quality, GPT Image 1.5 for transparency). Use when creating new assets for web projects that must match an existing design system or when extending a UI with new visual elements."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:web-replace-assets"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Autonomously scan, analyze, and replace image assets in web projects using AI-generated replacements. Detects tech stack, identifies existing assets with their dimensions/colors, generates new branded assets via Runware API (Nano Banana 2 for most use cases, GPT Image 1.5 for background removal), and replaces them while preserving layout. Use when modernizing a website's visuals, rebranding an existing project, or replacing placeholder/ benchmarked assets with original branded content. Supports autonomous execution with periodic visual verification."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:web-search"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Search the web in real-time using DDGS metasearch to find current information, recent news, documentation, and facts beyond knowledge cutoff. Aggregates results from Bing, Brave, Google, DuckDuckGo, Yahoo. Use when: user asks for recent news/current events/time-sensitive info, finding docs after knowledge cutoff, verifying facts/statistics with up-to-date sources, discovering recent products/services, or when user says 'search for', 'look up', 'find information about', or 'Google'. ALWAYS use for current information, recent updates, real-time data, or technical problems requiring current solutions."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:webapp-testing"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Test local development web applications using Python Playwright with automatic server lifecycle management. Use for: testing apps on localhost (ports 3000, 5173, 8000, etc.), starting dev servers automatically with with_server.py helper, testing during active development, multi-server setups (backend + frontend), and CI/CD testing of local builds. ALWAYS use when the user mentions localhost, local dev server, npm run dev, or needs automatic server startup/shutdown. DO NOT use for external/live websites - use playwright-cli skill instead. Keywords: localhost testing, local dev server, with_server.py, npm run dev, Python Playwright, development testing, server lifecycle, E2E testing local apps."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:webfetch-skill"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Fetch and analyze web content using a specialized sub-agent that converts HTML to clean markdown, extracts main article content, handles images and links, and provides AI analysis. Features 15-minute caching for performance. Use when - (1) Fetching and summarizing web pages or articles, (2) Extracting specific information from websites (emails, pricing, contact details), (3) Comparing content across multiple URLs (max 5), (4) Analyzing documentation or blog posts without external APIs, (5) Getting clean article content free of navigation/ads/boilerplate, (6) Extracting link summaries or image references from pages. ALWAYS use when the user asks to \"fetch\", \"extract\", or \"analyze\" a URL, requests content from a specific website, needs web page summarization, or wants to compare multiple web pages. Keywords - web scraping, content extraction, HTML to markdown, trafilatura, fetch URL, extract content, website analysis, article extraction, web crawler, content summarization, link extraction, web page parser."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:windows-form-filler"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Autonomously fill complex multi-page web forms on Windows 10 using a dedicated automation-ready Chrome instance plus human-in-the-loop pauses for sensitive information. Use when: filling insurance quotes, applications, registrations, onboarding flows, account forms, comparison journeys, or any long browser form where the user can provide a form URL, a profile file path, and optionally example screenshots from a similar form. ALWAYS use this skill on Windows when the task involves repeatedly mapping profile data into a live browser form while pausing for personal details, unclear questions, validation conflicts, and the final review stage."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:xlsx"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Comprehensive spreadsheet creation, editing, and analysis with support for formulas, formatting, data analysis, and visualization. When Claude needs to work with spreadsheets (.xlsx, .xlsm, .csv, .tsv, etc) for: (1) Creating new spreadsheets with formulas and formatting, (2) Reading or analyzing data, (3) Modify existing spreadsheets while preserving formulas, (4) Data analysis and visualization in spreadsheets, or (5) Recalculating formulas"]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:youtube-caption"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Fetch YouTube video captions/transcripts and metadata. Use when you need to download video transcripts, extract captions from YouTube URLs, get video descriptions and metadata, or process YouTube video text content. Supports residential proxy for reliable caption and metadata fetching (credentials auto-loaded from ~/.bashrc)."]]],["BUTTON",{"type":"button","class":"flex w-full items-center gap-2 rounded-md px-2 py-1 text-left text-sm transition-colors my-0.5 hover:bg-muted"},["svg",{"xmlns":"http://www.w3.org/2000/svg","width":"24","height":"24","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round","class":"lucide lucide-square-terminal size-3.5 shrink-0 text-muted-foreground","aria-hidden":"true"},["path",{"d":"m7 11 2-2-2-2"}],["path",{"d":"M11 13h4"}],["rect",{"width":"18","height":"18","x":"3","y":"3","rx":"2","ry":"2"}]],["SPAN",{"class":"truncate"},["SPAN",{"class":"font-medium text-primary"},"/","skill:youtube-search"],["SPAN",{"class":"ml-2 text-xs text-muted-foreground"},"Search YouTube videos by query or within specific channels. Supports date filtering, sort ordering, and duration filters to exclude YouTube S