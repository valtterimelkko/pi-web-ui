# Security-focused .gitignore

# Environment variables and secrets
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
secrets/
secrets.*
config/secrets*
credentials/
credentials.*

# API keys and tokens
*.apikey
*.token
auth.json
auth.config
tokens/

# Database
*.db
*.sqlite
*.sqlite3
*.sql
*.dump
data/
dumps/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov
.nyc_output

# Dependency directories
node_modules/
bower_components/
jspm_packages/
web_modules/
.pnp.*

# Build outputs
dist/
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/
.vite
temp/
tmp/

# IDE and editors
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Testing
cypress/videos/
cypress/screenshots/
__tests__/__snapshots__/

# Misc
*.tgz
*.tar.gz
*.zip
.fusebox/
.dynamodb/
.tern-port
.vscode-test
.yarn-integrity
*.local
